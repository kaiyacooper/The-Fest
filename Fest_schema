-- VIEWS

CREATE OR REPLACE VIEW v_frequent_bands AS
SELECT band_name, total_appearances, fest_editions, years_played,
       first_year, last_year, (last_year - first_year) AS year_span,
       hometown_city, hometown_state, hometown_country, latitude, longitude
FROM bands WHERE total_appearances >= 3 ORDER BY total_appearances DESC;

CREATE OR REPLACE VIEW v_edition_summary AS
SELECT e.edition, e.year, e.name, e.num_stages,
       e.start_date, e.end_date,
       DATEDIFF(e.end_date, e.start_date) + 1 AS duration_days,
       e.cancelled,
       COUNT(DISTINCT a.band_name) AS bands_in_db
FROM fest_editions e
LEFT JOIN band_appearances a ON e.edition = a.fest_edition
GROUP BY e.edition, e.year, e.name, e.num_stages, e.start_date, e.end_date, e.cancelled
ORDER BY e.year;

CREATE OR REPLACE VIEW v_map_data AS
SELECT b.band_name, b.hometown_city, b.hometown_state, b.hometown_country,
       b.latitude, b.longitude, b.total_appearances,
       b.first_year, b.last_year, b.fest_editions
FROM bands b
WHERE b.latitude IS NOT NULL
ORDER BY b.total_appearances DESC;

CREATE OR REPLACE VIEW v_bands_by_state AS
SELECT hometown_state, hometown_country,
       COUNT(*) AS band_count,
       SUM(total_appearances) AS total_appearances
FROM bands WHERE hometown_state IS NOT NULL
GROUP BY hometown_state, hometown_country
ORDER BY band_count DESC;

CREATE OR REPLACE VIEW v_bands_by_country AS
SELECT hometown_country,
       COUNT(*) AS band_count,
       SUM(total_appearances) AS total_appearances
FROM bands WHERE hometown_country IS NOT NULL
GROUP BY hometown_country ORDER BY band_count DESC;



-- EXAMPLE QUERIES


-- Q1: Top 20 bands by appearances
SELECT band_name, total_appearances, hometown_city, hometown_state,
       hometown_country, fest_editions
FROM bands ORDER BY total_appearances DESC LIMIT 20;

-- Q2: Which US states sent the most bands?
SELECT * FROM v_bands_by_state WHERE hometown_country = 'USA';

-- Q3: International bands (non-US)
SELECT band_name, hometown_city, hometown_country, total_appearances
FROM bands WHERE hometown_country != 'USA' AND hometown_country IS NOT NULL
ORDER BY hometown_country, total_appearances DESC;

-- Q4: Gainesville locals vs out-of-towners ratio
SELECT
  SUM(CASE WHEN hometown_city = 'Gainesville' THEN 1 ELSE 0 END) AS local_bands,
  SUM(CASE WHEN hometown_city != 'Gainesville'
           AND hometown_city IS NOT NULL THEN 1 ELSE 0 END) AS touring_bands
FROM bands;

-- Q5: Unique bands per edition
SELECT fest_edition, year, COUNT(DISTINCT band_name) AS unique_bands
FROM band_appearances GROUP BY fest_edition, year ORDER BY fest_edition;

-- Q6: Bands that played 3+ editions (the loyalists)
SELECT * FROM v_frequent_bands;

-- Q7: All map data for Power BI / Tableau
SELECT * FROM v_map_data;

-- Q8: Which city has produced the most FEST bands?
SELECT hometown_city, hometown_state, hometown_country, COUNT(*) AS bands
FROM bands WHERE hometown_city IS NOT NULL
GROUP BY hometown_city, hometown_state, hometown_country
ORDER BY bands DESC LIMIT 15;
