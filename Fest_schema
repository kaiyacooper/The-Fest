-- THE FEST DATABASE v3
-- Gainesville, Florida  |  2002-2025  |  23 Editions
-- New in v3: hometown city/state/country + lat/lon for map visuals
-- Sources: Concert Archives, setlist.fm, thefestfl.com,
--          Grooveist, MusicBrainz, Wikipedia

DROP DATABASE IF EXISTS the_fest;
CREATE DATABASE the_fest CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE the_fest;

CREATE TABLE fest_editions (
  edition       TINYINT UNSIGNED,
  year          YEAR NOT NULL,
  name          VARCHAR(60) NOT NULL,
  start_date    DATE,
  end_date      DATE,
  num_stages    TINYINT UNSIGNED,
  cancelled     TINYINT(1) NOT NULL DEFAULT 0,
  notes         TEXT,
  setlistfm_id  VARCHAR(20),
  PRIMARY KEY (year),
  UNIQUE KEY uk_edition (edition)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE venues (
  venue_id      SMALLINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
  name          VARCHAR(100) NOT NULL,
  type          VARCHAR(30),
  capacity_tier VARCHAR(25),
  years_active  VARCHAR(20),
  notes         TEXT
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE concerts (
  concert_id    SMALLINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
  fest_edition  TINYINT UNSIGNED,
  concert_name  VARCHAR(80),
  day_label     VARCHAR(10),
  concert_date  DATE,
  year          YEAR,
  source_url    TEXT,
  CONSTRAINT fk_concert_edition
    FOREIGN KEY (fest_edition) REFERENCES fest_editions(edition)
    ON DELETE SET NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE bands (
  band_id             SMALLINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
  band_name           VARCHAR(200) NOT NULL,
  total_appearances   SMALLINT UNSIGNED DEFAULT 0,
  fest_editions       VARCHAR(60),
  years_played        VARCHAR(60),
  first_year          YEAR,
  last_year           YEAR,
  hometown_city       VARCHAR(80),
  hometown_state      VARCHAR(50),
  hometown_country    VARCHAR(50),
  latitude            DECIMAL(8,4),
  longitude           DECIMAL(8,4),
  UNIQUE KEY uk_band_name (band_name),
  KEY idx_country (hometown_country),
  KEY idx_state   (hometown_state)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE band_appearances (
  appearance_id   INT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
  concert_id      SMALLINT UNSIGNED,
  band_id         SMALLINT UNSIGNED,
  fest_edition    TINYINT UNSIGNED,
  band_name       VARCHAR(200),
  concert_date    DATE,
  year            YEAR,
  CONSTRAINT fk_app_concert FOREIGN KEY (concert_id) REFERENCES concerts(concert_id) ON DELETE CASCADE,
  CONSTRAINT fk_app_band    FOREIGN KEY (band_id)    REFERENCES bands(band_id)    ON DELETE SET NULL,
  KEY idx_band_id   (band_id),
  KEY idx_edition   (fest_edition),
  KEY idx_year      (year),
  KEY idx_band_name (band_name)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE top_performers (
  rank_position   TINYINT UNSIGNED NOT NULL PRIMARY KEY,
  band_name       VARCHAR(200) NOT NULL,
  setlistfm_count TINYINT UNSIGNED,
  grooveist_rank  TINYINT UNSIGNED,
  notes           TEXT
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE genres (
  genre_id          TINYINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
  genre             VARCHAR(50) NOT NULL,
  performance_count SMALLINT UNSIGNED,
  source            VARCHAR(50) DEFAULT 'Concert Archives'
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

